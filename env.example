# Morning Briefing — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── SMTP (outbound email) ──────────────────────────────────────────────────────
# Gmail users: generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2-step verification to be enabled on your account).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# ── Recipient ─────────────────────────────────────────────────────────────────

EMAIL_TO=you@gmail.com

# ── Plugins ───────────────────────────────────────────────────────────────────
# Override the plugin directory. Relative paths resolve from the project root.
# Absolute paths are used as-is. Defaults to src/morning_briefing/plugins/.
#
# Examples:
#   PLUGINS_DIR=my_plugins
#   PLUGINS_DIR=/home/jack/briefing-plugins
#
# PLUGINS_DIR=
